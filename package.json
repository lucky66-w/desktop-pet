{\n  "name": "desktop-pet",\n  "version": "1.0.0",\n  "description": "高级桌面宠物 - 可爱的猫咪陪伴程序",\n  "main": "main.js",\n  "homepage": "./",\n  "author": "lucky66-w",\n  "license": "MIT",\n  "scripts": {\n    "start": "concurrently \"npm run react-start\" \"wait-on http://localhost:3000 && electron .\"",\n    "react-start": "react-scripts start",\n    "react-build": "react-scripts build",\n    "build": "npm run react-build",\n    "pack": "npm run react-build && electron-builder",\n    "eject": "react-scripts eject"\n  },\n  "dependencies": {\n    "react": "^18.2.0",\n    "react-dom": "^18.2.0",\n    "electron-squirrel-startup": "^1.1.1",\n    "howler": "^2.2.3",\n    "pixi.js": "^7.3.0",\n    "uuid": "^9.0.0"\n  },\n  "devDependencies": {\n    "react-scripts": "5.0.1",\n    "electron": "^latest",\n    "electron-builder": "^24.6.4",\n    "concurrently": "^8.2.0",\n    "wait-on": "^7.0.1",\n    "electron-is-dev": "^2.0.0"\n  },\n  "build": {\n    "appId": "com.desktop-pet.app",\n    "productName": "桌面宠物",\n    "files": [\n      "build/**/*",\n      "main.js",\n      "preload.js",\n      "package.json"\n    ],\n    "directories": {\n      "buildResources": "public"\n    },\n    "win": {\n      "target": [\n        "nsis",\n        "portable"\n      ]\n    },\n    "nsis": {\n      "oneClick": false,\n      "allowToChangeInstallationDirectory": true\n    }\n  }\n}\n